# OpenAI API Key for LLM Player functionality
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: Custom OpenAI API base URL (for enterprise or proxy setups)
# Example: https://api.openai.com/v1
OPENAI_API_BASE_URL=

# Optional: Default LLM model for AI players
# Defaults to: gpt-4o-mini
LLM_MODEL=

# Supabase Configuration
# Create a project at https://supabase.com and copy the values from Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# ⚠️ WARNING: Service role key bypasses Row Level Security. Treat it as a secret.
# Never expose it to the browser or commit it to version control.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: Development/Production environment
# NODE_ENV=development
